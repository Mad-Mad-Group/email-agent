{
  "name": "lead-cms-worker",
  "version": "1.0.0",
  "description": "AI Agent worker — claim tasks from NestJS API, call Hermes agent",
  "scripts": {
    "build": "tsc",
    "worker": "node --env-file=.env dist/agent.js",
    "leader": "node --env-file=.env dist/leader.js",
    "start": "npm run build && npm run leader",
    "start:single": "npm run build && npm run worker"
  },
  "dependencies": {
    "imapflow": "^1.4.3",
    "mailparser": "^3.9.12",
    "mongodb": "^6.0.0",
    "nodemailer": "^6.10.1"
  },
  "devDependencies": {
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.24",
    "typescript": "^5.0.0"
  }
}
